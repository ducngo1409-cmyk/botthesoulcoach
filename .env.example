# --- Required ---
TELEGRAM_TOKEN=put-your-bot-token-from-BotFather-here
SUPERVISOR_CHAT_ID=123456789
GEMINI_API_KEY=put-your-gemini-api-key-here

# --- Access control (v2.8) ---
# If 1 (default): new users land in 'pending' state after /start. Supervisor
# gets a DM with approve/reject buttons. Until approved, user can't use the
# bot. Set to 0 to auto-approve everyone (for testing or fully-open instances).
REQUIRE_APPROVAL=1

# If 1 (default), approved users MUST complete timezone onboarding before
# using other commands. Set to 0 only for testing/dev.
REQUIRE_ONBOARDING=1

# --- LLM ---
# Comma-separated failover chain. Each model has its own free-tier quota bucket.
GEMINI_MODEL=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash
# Optional second key from a DIFFERENT Google account for true quota failover.
GEMINI_API_KEY_2=

# --- Storage & scheduling ---
DB_PATH=data/soul_coach.db
DEFAULT_TZ=Asia/Ho_Chi_Minh
REMINDER_NUDGE_HOURS=12
REMINDER_MISS_HOURS=24
REPORT_CRON=0 18 * * SUN

# --- Tuning ---
FUZZY_THRESHOLD=65
SAT_THRESHOLD=10
LOG_LEVEL=INFO
HEALTH_PORT=8080
